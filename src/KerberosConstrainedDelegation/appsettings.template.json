{
  "ServiceAccount": {
    "Username": "YOUR_SERVICE_ACCOUNT_USERNAME",
    "Domain": "YOUR_DOMAIN",
    "Password": "YOUR_SERVICE_ACCOUNT_PASSWORD"
  },
  "TargetUser": {
    "Username": "target.user@yourdomain.com"
  },
  "TargetService": {
    "Spn": "cifs/fileserver.yourdomain.com"
  },
  "ExternalExecutable": {
    "Path": "C:\\Path\\To\\FileShareWriter.exe"
  },
  "FileShare": {
    "Path": "\\\\fileserver\\share\\test.txt"
  },
  "Execution": {
    "TimeoutSeconds": 30
  }
}
